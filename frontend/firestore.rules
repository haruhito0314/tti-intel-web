rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Threads collection
    match /threads/{threadId} {
      // Anyone can read threads
      allow read: if true;
      
      // Anyone can create a thread (anonymous posting)
      // Validate that required fields are present and types are correct
      allow create: if 
        request.resource.data.keys().hasAll(['title', 'body', 'displayName', 'createdAt', 'commentCount', 'pinned', 'locked']) &&
        request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 100 &&
        request.resource.data.body is string && request.resource.data.body.size() > 0 && request.resource.data.body.size() <= 1000 &&
        request.resource.data.displayName is string && request.resource.data.displayName.size() <= 50 &&
        request.resource.data.commentCount == 0 &&
        request.resource.data.pinned == false &&
        request.resource.data.locked == false;

      // Allow updating ONLY the commentCount field (for when a new comment is added)
      // Prevent updating if the thread is locked
      allow update: if 
        resource.data.locked == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']) &&
        request.resource.data.commentCount == resource.data.commentCount + 1;
        
      // Only admins should be able to delete, pin, or lock (not implemented yet, so deny all)
      allow delete: if false;

      // Comments subcollection
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;
        
        // Anyone can create a comment if the parent thread is NOT locked
        allow create: if 
          get(/databases/$(database)/documents/threads/$(threadId)).data.locked == false &&
          request.resource.data.keys().hasAll(['body', 'displayName', 'createdAt']) &&
          request.resource.data.body is string && request.resource.data.body.size() > 0 && request.resource.data.body.size() <= 500 &&
          request.resource.data.displayName is string && request.resource.data.displayName.size() <= 50;

        // Comments cannot be updated or deleted by anonymous users
        allow update, delete: if false;
      }
    }
  }
}
